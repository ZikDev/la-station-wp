{% extends "base.twig" %}

{% block content %}
    <main>
        <h1>{{ title }}</h1>
        <p>{{ category }}</p>
        
        {% if domain_technician %}
            <p>{{ domain_technician|map(s => s.name)|join(', ') }}</p>
        {% endif %}

        {% if domain_organization %}
            <p>{{ domain_organization|map(s => s.name)|join(', ') }}</p>
        {% endif %}

        {% if style %}
            <p>{{ style|map(s => s.name)|join(', ') }}</p>
        {% endif %}

        {% if instrument %}
            <p>{{ instrument|map(s => s.name)|join(', ') }}</p>
        {% endif %}

        {% if location_type %}
            <p>{{ location_type|map(s => s.name)|join(', ') }}</p>
        {% endif %}
 
        <p>{{ name }}</p>

        {% if first_name %}
            <p>{{ first_name }}</p>
        {% endif %}

        {% if creation_year.name %}
            <p>{{ creation_year.name }}</p>
        {% endif %}

        {% if email %}
            <a href="mailto:{{ email }}">{{ email }}</a> </br>
        {% endif %}

        {% if phone_number %}
            <a href="tel:+{{ phone_number }}">{{ phone_number }}</a> </br>
        {% endif %}

        <p>{{ district.name }}</p>

        {% if years_of_experience.name %}
            <p>{{ years_of_experience.name }}</p>
        {% endif %}

        <img src="{{ profile_picture.url }}" />

        {% if description %}
            <p>{{ description }}</p>
        {% endif %}

        <a href="{{ website }}">{{ website }}</a> </br>

        {% if video_1 %}
            <a href="{{ video_1 }}">{{ video_1 }}</a> </br>
        {% endif %}
        {% if video_2 %}
            <a href="{{ video_2 }}">{{ video_2 }}</a> </br>
        {% endif %}
        {% if video_3 %}
            <a href="{{ video_3 }}">{{ video_3 }}</a> </br>
        {% endif %}
        {% if instagram %}
            <a href="{{ instagram }}">{{ instagram }}</a> </br>
        {% endif %}
        {% if youtube %}
            <a href="{{ youtube }}">{{ youtube }}</a> </br>
        {% endif %}
        {% if tiktok %}
            <a href="{{ tiktok }}">{{ tiktok }}</a> </br>
        {% endif %}
        {% if facebook %}
            <a href="{{ facebook }}">{{ facebook }}</a>
        {% endif %}

    </main>
{% endblock %}
