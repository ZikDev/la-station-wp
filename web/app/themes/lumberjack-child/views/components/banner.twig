{#
  Composant Banner pour les messages de feedback
  Usage: {% include 'components/banner.twig' with { type: 'success', message: 'Message réussi!' } %}
#}

{% if message %}
	{% set current_type = type|default('info') %}
	{% set icons = {
    'success': '✓',
    'error': '✕',
    'warning': '⚠',
    'info': 'ℹ'
  } %}
	{% set current_icon = icons[current_type]|default(icons.info) %}

	<div class="banner banner--{{ current_type }}" role="alert" data-banner="true">

		<div class="banner__body">
			<!-- Icône -->
			<div class="banner__icon-wrap">
				<span class="banner__icon">{{ current_icon }}</span>
			</div>

			<!-- Contenu du message -->
			<div class="banner__content">
				{% if title %}
					<h3 class="banner__title">{{ title }}</h3>
				{% endif %}
				<div class="banner__message">{{ message|raw }}</div>
			</div>
		</div>

		<!-- Bouton de fermeture -->
		{% if dismissible|default(true) %}
			<div class="banner__dismiss-wrap">
				<button data-banner-dismiss class="banner__dismiss">
					<span class="sr-only">Fermer</span>
					<svg class="banner__dismiss-icon" fill="currentColor" viewbox="0 0 20 20">
						<path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path>
					</svg>
				</button>
			</div>
		{% endif %}
	</div>
{% endif %}
