{# templates/emails/welcome.twig #}
{% extends "emails/base.twig" %}
{% block title %}
	Bienvenue
	{{ name }}
	-
	{{ site_name }}
{% endblock %}
{% block header_title %}
	Bienvenue
	{{ name }}
	!
{% endblock %}

{% block content %}
	<h2>
		Votre compte a été créé avec succès
	</h2>
	<p>
		Bonjour<strong>
			{{ name }}
		</strong>
		,
	</p>
	<p>Nous avons le plaisir de vous confirmer que votre compte a été créé avec succès sur le site de
		<strong>
			{{ site_name }}
		</strong>
		.
	</p>

	<div class="info-box">
		<h3 style="margin-top: 0; color: #495057;">
			<span style="color: #ff457d;">🔐</span>
			Vos informations de connexion
		</h3>

		<p>
			<strong>URL de connexion :</strong>
		</p>
		<p>
			<a href="{{ login_url }}" class="button">Se connecter maintenant</a>
		</p>

		<div class="credentials">
			<p>
				<strong>Nom d'utilisateur :</strong>
				{{ email }}</p>
			<p>
				<strong>Mot de passe temporaire :</strong>
				{{ password }}</p>
		</div>
	</div>

	<div class="warning-box">
		<p style="margin: 0;">
			<strong>⚠️ Important :</strong>
			Pour des raisons de sécurité, nous vous recommandons fortement de changer votre mot de passe lors de votre première connexion.
		</p>
	</div>

	<h3>Prochaines étapes</h3>
	<ol>
		<li>Cliquez sur le bouton "Se connecter maintenant" ci-dessus</li>
		<li>Utilisez vos identifiants pour vous connecter</li>
		<li>Changez votre mot de passe temporaire sur votre page de profil</li>
		<li>Compléter les informations de votre page "Profile" en vous référant au guide ci-joint si nécessaire.</li>
	</ol>

	<p style="margin-top: 30px;">
		Si vous rencontrez des difficultés ou avez des questions, n'hésitez pas à nous contacter à
		<a href="mailto:{{ contact_email }}">{{ contact_email }}</a>.
	</p>

	<p>
		<strong>L'équipe
			{{ site_name }}</strong><br>
		<em>Nous sommes ravis de vous compter parmi nous !</em>
	</p>
{% endblock %}
